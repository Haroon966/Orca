# Orca UI Environment Configuration
# Only includes variables that are actually used in the code
#
# TIP: Run 'orca status' to see where this file should be located
#      and to view your current configuration.
#
# Available CLI commands:
#   orca              - Start the server (default)
#   orca start        - Start the server
#   orca status       - Show configuration and data locations
#   orca help         - Show help information
#   orca version      - Show version information

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Backend server port (Express API + WebSocket server)
#API server
SERVER_PORT=3001
#Frontend port
VITE_PORT=5173

# Host/IP to bind servers to (default: 0.0.0.0 for all interfaces)
# Use 127.0.0.1 to restrict to localhost only
HOST=0.0.0.0

# Uncomment the following line if you have a custom claude cli path other than the default "claude"
# CLAUDE_CLI_PATH=claude

# Skip login screen for trusted local use (Orca default).
# Set DISABLE_AUTH=false and VITE_DISABLE_AUTH=false when exposing on a network.
# DISABLE_AUTH=true
# VITE_DISABLE_AUTH=true

# =============================================================================
# BRANDING (optional)
# =============================================================================

# VITE_GITHUB_OWNER=Haroon966
# VITE_GITHUB_REPO=Orca

# =============================================================================
# DATABASE
# =============================================================================

# Path to SQLite auth database (default: ~/.orca/auth.db)
# DATABASE_PATH=/path/to/auth.db

# Optional remote skills marketplace catalog URL (JSON). Falls back to bundled catalog.
# ORCA_SKILLS_CATALOG_URL=https://raw.githubusercontent.com/Haroon966/Orca/main/server/modules/skills-marketplace/data/skills-catalog.json

# Claude Code context window size (maximum tokens per session)
VITE_CONTEXT_WINDOW=160000
CONTEXT_WINDOW=160000

# =============================================================================
# RELEASE (maintainers only — add to .env, never commit)
# =============================================================================
#
# GitHub ↔ npm connection is for "Trusted Publishing" (CI publish without tokens).
# It is NOT the same as npm Organizations. You already own org "orca_ai" on npm.
#
# Option A — local publish (first time or manual):
#   1. https://www.npmjs.com/settings/~/tokens → Granular Access Token
#   2. Permissions: Read and write
#   3. Under "Select packages and scopes" OR "Organizations": grant orca_ai / @orca_ai
#   4. Enable "Bypass two-factor authentication (2FA)" at creation
#   5. npm run publish:npm
#
# Option B — one-time OTP (if token org access is confusing):
#   npm publish --access public --otp=123456
#
# Option C — GitHub Actions trusted publishing (no NPM_TOKEN):
#   Configure on npmjs.com → @orca_ai/orca → Trusted Publisher → publish-npm.yml
#   Then push a tag (v*) or run the workflow manually.
#
# GitHub PAT with repo scope — used by release-it
# GITHUB_TOKEN=ghp_...
#
# npm granular token (Option A)
# NPM_TOKEN=npm_...

# Orca default: set AUTH_BYPASS=true for local-only dev without login
# AUTH_BYPASS=true
